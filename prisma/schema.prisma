generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Store {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logo        String?
  websiteUrl  String?
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coupons  Coupon[]
  cashback CashbackOffer[]
}

model Coupon {
  id           String       @id @default(cuid())
  storeId      String
  source       String // amazon, flipkart, cuelinks, manual
  externalId   String?
  title        String
  description  String?
  code         String?
  discount     String?
  category     String?
  bank         String?
  affiliateUrl String?
  expiresAt    DateTime?
  verified     Boolean      @default(true)
  isFeatured   Boolean      @default(false)
  isActive     Boolean      @default(true)
  status       CouponStatus @default(PUBLISHED)
  clicks       Int          @default(0)
  usesToday    Int          @default(0)
  terms        Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  rawPayload   Json?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([source, externalId], name: "coupon_source_externalId")
  @@index([storeId])
  @@index([source])
}

model CashbackOffer {
  id            String    @id @default(cuid())
  storeId       String
  source        String // amazon, flipkart, cuelinks, manual
  externalId    String?
  title         String
  description   String?
  cashbackType  String // percent | flat
  cashbackValue Float
  affiliateUrl  String
  terms         String?
  isFeatured    Boolean   @default(false)
  isActive      Boolean   @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  clicks        Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  rawPayload    Json?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([source, externalId], name: "cashback_source_externalId")
  @@index([storeId])
  @@index([source])
}

model CouponSubmission {
  id           String           @id @default(cuid())
  storeName    String
  storeSlug    String?
  title        String
  description  String?
  code         String?
  discount     String?
  category     String?
  affiliateUrl String?
  submitter    String?
  notes        String?
  status       SubmissionStatus @default(PENDING)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model OfferClick {
  id          String   @id @default(cuid())
  offerType   String // coupon | cashback
  offerId     String
  source      String?
  storeSlug   String?
  destination String
  createdAt   DateTime @default(now())

  @@index([offerType, offerId])
  @@index([storeSlug])
}

model PromoBanner {
  id             String   @id @default(cuid())
  title          String
  subtitle       String?
  imageUrl       String
  mobileImageUrl String?
  ctaText        String?
  ctaUrl         String?
  bannerType     String   // hero | horizontal | vertical | square
  placement      String   // homepage_top | homepage_middle | sidebar | store_page | category_page
  storeSlug      String?
  category       String?
  source         String?  // manual | affiliate
  externalId     String?
  priority       Int      @default(0)
  isActive       Boolean  @default(true)
  startsAt       DateTime?
  endsAt         DateTime?
  rawPayload     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([placement])
  @@index([category])
  @@index([storeSlug])
  @@index([isActive])
  @@index([priority])
  @@index([source])
}

model HomepageSectionControl {
  id         String   @id @default(cuid())
  sectionKey String   @unique // hero, great_offers, top_brands, categories, featured_coupons, promo_row
  title      String
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model HomepageFeaturedOffer {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  imageUrl      String?
  storeName     String
  storeSlug     String
  priceText     String?
  oldPriceText  String?
  discountText  String?
  bankOfferText String?
  cashbackText  String?
  validTillText String?
  ctaText       String?  @default("View Deal")
  ctaUrl        String?
  category      String?
  source        String?  // manual | affiliate
  externalId    String?
  priority      Int      @default(0)
  isActive      Boolean  @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  rawPayload    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([storeSlug])
  @@index([category])
  @@index([isActive])
  @@index([priority])
  @@index([source])
}

enum CouponStatus {
  DRAFT
  PUBLISHED
  EXPIRED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}